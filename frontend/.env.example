# Frontend build-time variables (Vite).
#
# Development:
#   cp .env.example .env
#   npm run dev
#
# Production (Docker):
#   Leave VITE_API_BASE empty — nginx serves the SPA and proxies API routes
#   on the same domain. The frontend Dockerfile sets this automatically.

# Backend base URL baked into the production JS bundle.
# Empty = same-origin (/config, /voice/token, /interview/… via nginx proxy).
VITE_API_BASE=

# Dev only — Vite dev-server proxy target (not used in Docker production build).
# VITE_API_PROXY=http://127.0.0.1:8000
