# ---------------------------------------------------------------------------
# Central LLM selection. Swap provider/model here to test different models.
# provider: openai | anthropic | google | ollama | deepseek | moonshot
# Examples:
#   LLM_PROVIDER=deepseek   LLM_MODEL=deepseek-chat   (use deepseek-chat, NOT
#                                                       deepseek-reasoner)
#   LLM_PROVIDER=moonshot   LLM_MODEL=kimi-k2.5       (Kimi)
# ---------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=1024

# Optional per-role overrides (interviewer = creative, evaluator = strict).
# INTERVIEWER_MODEL=gpt-4o
# INTERVIEWER_TEMPERATURE=0.8
# EVALUATOR_MODEL=gpt-4o-mini
EVALUATOR_TEMPERATURE=0.0

# ---------------------------------------------------------------------------
# Provider credentials. Only the one matching LLM_PROVIDER is required.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
# Moonshot international endpoint by default; use https://api.moonshot.cn/v1 for China
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# ---------------------------------------------------------------------------
# Interview behaviour
# ---------------------------------------------------------------------------
MAX_PROBES_PER_TOPIC=2

# ---------------------------------------------------------------------------
# Session persistence. backend: memory | sqlite
# memory is NOT safe across multiple uvicorn workers; use sqlite (or Postgres).
# ---------------------------------------------------------------------------
CHECKPOINTER_BACKEND=sqlite
SQLITE_PATH=./interview_sessions.db

# ---------------------------------------------------------------------------
# Optional: push the finished report to your backend automatically.
# ---------------------------------------------------------------------------
# REPORT_WEBHOOK_URL=https://your-backend.example.com/visa-reports

# ---------------------------------------------------------------------------
# Optional: LangSmith tracing for observability / per-interview cost.
# Set LANGSMITH_TRACING=true and LANGSMITH_API_KEY, then open LangSmith →
# project LANGSMITH_PROJECT → Threads tab → find thread id = interview session_id.
# LLM cost is automatic; voice infra (STT/TTS/LiveKit) is estimated at session end.
# ---------------------------------------------------------------------------
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=
LANGSMITH_PROJECT=visa-interviewer

# Estimated USD/min for voice infra (calibrate against provider invoices).
COST_DEEPGRAM_STT_USD_PER_MIN=0.0048
COST_CARTESIA_TTS_USD_PER_MIN=0.05
COST_LIVEKIT_AGENT_USD_PER_MIN=0.01

# ---------------------------------------------------------------------------
# Voice interview (LiveKit Cloud + Deepgram STT + Cartesia/OpenAI/ElevenLabs TTS).
# Leave blank to keep the text-only API; voice activates when these are set.
# ---------------------------------------------------------------------------
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
# Deepgram silence (ms) before finalizing a phrase; higher = fewer mid-sentence splits.
DEEPGRAM_ENDPOINTING_MS=400
# Seconds to wait after user stops speaking before the officer responds.
VOICE_MIN_ENDPOINTING_DELAY=1.2
VOICE_MAX_ENDPOINTING_DELAY=6.0

# TTS provider for the voice agent: cartesia | openai | elevenlabs
TTS_PROVIDER=cartesia

# Cartesia (default TTS).
CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-2
# Optional global voice override; if set, skips region/gender shuffle below.
# CARTESIA_VOICE=
# Region voices (defaults baked in; override to swap Cartesia voice ids).
# CARTESIA_VOICE_UK_MALE=4bc3cb8c-adb9-4bb8-b5d5-cbbef950b991
# CARTESIA_VOICE_UK_FEMALE=dc30854e-e398-4579-9dc8-16f6cb2c19b9
# CARTESIA_VOICE_US_MALE=a167e0f3-df7e-4d52-a9c3-f949145efdab
# CARTESIA_VOICE_US_FEMALE=10bd4af4-825b-49b8-b8bd-0ca11865536e

# OpenAI TTS (alternative). Reuses OPENAI_API_KEY above.
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# ElevenLabs (alternative).
ELEVENLABS_API_KEY=
# Optional ElevenLabs voice; uses the plugin default if blank.
# ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Fallback interview type when the voice client sends none.
VOICE_DEFAULT_COUNTRY=US
VOICE_DEFAULT_VISA_TYPE=F1

# ---------------------------------------------------------------------------
# HTTP server
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
