# =============================================================================
# Production environment — copy to .env on the server and fill in all secrets.
#   cp .env.production.example .env
#
# Development: use .env.example locally (uv run / npm run dev).
# =============================================================================

# -----------------------------------------------------------------------------
# Deployment / Nginx / SSL
# -----------------------------------------------------------------------------
# Public hostname for this deployment (DNS A record must point to the server).
APP_DOMAIN=<new-subdomain.example.com>

# Email for Let's Encrypt expiry notices (required for init-ssl.sh).
CERTBOT_EMAIL=admin@example.com

# Nginx template: HTTP bootstrap first, then HTTPS after certbot (init-ssl.sh sets this).
NGINX_TEMPLATE=/etc/nginx/templates/app-http.conf.template

# -----------------------------------------------------------------------------
# LLM provider (required — pick one provider and set its API key below)
# -----------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=1024

# Optional per-role overrides
# INTERVIEWER_MODEL=gpt-4o
INTERVIEWER_TEMPERATURE=0.85
# EVALUATOR_MODEL=gpt-4o-mini
EVALUATOR_TEMPERATURE=0.0

PROMPT_VERSION=v1

# Provider credentials — set the key matching LLM_PROVIDER
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# -----------------------------------------------------------------------------
# Interview behaviour
# -----------------------------------------------------------------------------
MAX_PROBES_PER_TOPIC=2

# -----------------------------------------------------------------------------
# Session persistence (shared volume between api + voice-agent containers)
# -----------------------------------------------------------------------------
CHECKPOINTER_BACKEND=sqlite
SQLITE_PATH=/data/interview_sessions.db

# -----------------------------------------------------------------------------
# Optional: push completed text-interview reports to your backend
# -----------------------------------------------------------------------------
# REPORT_WEBHOOK_URL=https://your-backend.example.com/visa-reports

# -----------------------------------------------------------------------------
# Optional: LangSmith tracing
# -----------------------------------------------------------------------------
LANGSMITH_TRACING=false
# LANGSMITH_API_KEY=
LANGSMITH_PROJECT=visa-interviewer

COST_DEEPGRAM_STT_USD_PER_MIN=0.0048
COST_CARTESIA_TTS_USD_PER_MIN=0.05
COST_LIVEKIT_AGENT_USD_PER_MIN=0.01

# -----------------------------------------------------------------------------
# Voice interview (optional — enable with: docker compose --profile voice up -d)
# Requires LiveKit Cloud + Deepgram + TTS provider keys.
# -----------------------------------------------------------------------------
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
DEEPGRAM_ENDPOINTING_MS=300
VOICE_MIN_ENDPOINTING_DELAY=0.6
VOICE_MAX_ENDPOINTING_DELAY=3.0
VOICE_FAST_MODE=true

TTS_PROVIDER=cartesia
CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-2
# CARTESIA_VOICE=

OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

VOICE_DEFAULT_COUNTRY=US
VOICE_DEFAULT_VISA_TYPE=F1

# -----------------------------------------------------------------------------
# HTTP server (internal — nginx proxies public traffic here)
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
